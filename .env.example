# ─────────────────────────────────────────────────────────────────────────────
# LifeController environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml. Change the password for production!
DATABASE_URL=postgres://lifecontroller:change_me_in_prod@localhost:5432/lifecontroller

# ── Auth.js / NextAuth ────────────────────────────────────────────────────────
# Public URL of the app. For local dev: http://localhost:3000
# For your VPS:  https://your-domain.example
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret:  openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_base64_32

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
#   - OAuth 2.0 Client ID, type "Web application"
#   - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#     (and https://your-domain.example/api/auth/callback/google for prod)
AUTH_GOOGLE_ID=replace_with_google_client_id
AUTH_GOOGLE_SECRET=replace_with_google_client_secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# The email that is ALWAYS treated as the super-admin (auto-approved on first login).
ADMIN_EMAIL=avikane@gmail.com
# Break-glass admin code. Preferred location is settings.json (adminSecureCode),
# but in containerized deploys you can set it here instead. Generate: openssl rand -hex 32
ADMIN_SECURE_CODE=

# ── Anthropic / Claude ──────────────────────────────────────────────────────────
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
# Model used by the search agent (kept current with the latest Claude models).
ANTHROPIC_MODEL=claude-opus-4-8
# Embedding model. Anthropic does not host embeddings, so we use Voyage AI
# (Anthropic's recommended embeddings partner). Get a key at https://www.voyageai.com/
# If left blank, the app falls back to keyword-only search (no semantic recall).
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large

# ── File storage ────────────────────────────────────────────────────────────────
# Local-disk directory where uploaded files/receipts/images are stored.
UPLOAD_DIR=./uploads
# Max upload size in MB.
MAX_UPLOAD_MB=25

# ── Web search fallback ──────────────────────────────────────────────────────────
# The "find docs online" feature uses Claude's built-in web_search tool, which is
# billed through your ANTHROPIC_API_KEY. No extra key required.
ENABLE_WEB_SEARCH=true

# ── Proactive: Telegram bot (capture + notifications) ────────────────────────────
# Optional. Lets you message a private bot to capture into your inbox, and receive
# the daily briefing. Create a bot with @BotFather to get the token; message the
# bot once, then read your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
# (the "chat":{"id":...}). Register the webhook (one-time):
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://things.vikane.cloud/api/telegram&secret_token=<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# A secret you choose (openssl rand -hex 32); Telegram echoes it back on every
# webhook call so we can reject forged requests.
TELEGRAM_WEBHOOK_SECRET=
# Which account captures are filed under (defaults to ADMIN_EMAIL).
TELEGRAM_OWNER_EMAIL=

# ── Proactive: scheduled daily briefing + suggestion scan ────────────────────────
# Secret guarding the cron endpoints (shared by the digest and the suggestions scan).
# Trigger from the host crontab, e.g.:
#   0 7 * * *  curl -fsS -H "x-cron-secret: <CRON_SECRET>" https://things.vikane.cloud/api/cron/digest
# The proactive "connect the dots" scan (duplicates / links / fillable gaps) can run
# on its own schedule against the same secret (it resolves to the configured owner):
#   30 6 * * *  curl -fsS -H "x-cron-secret: <CRON_SECRET>" https://things.vikane.cloud/api/suggestions/scan
# Generate: openssl rand -hex 32. Leave blank to disable the endpoints entirely.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Docker on a VM) — set these for a real deploy.
# ─────────────────────────────────────────────────────────────────────────────
# Strong Postgres password used by both the db container and the app's DATABASE_URL
# (compose builds the URL from this). Generate: openssl rand -hex 24
POSTGRES_PASSWORD=replace_with_strong_db_password
#
# Public URL of the site — MUST match the Google OAuth redirect domain.
#   AUTH_URL=https://things.vikane.cloud
#   NEXTAUTH_URL=https://things.vikane.cloud
# Google OAuth redirect URI to add in Google Console:
#   https://things.vikane.cloud/api/auth/callback/google
# (trustHost is enabled in code, so the app works behind Traefik/Caddy.)

# ── Option A: behind your existing Traefik (compose.vm.yml) — vikane.cloud setup ──
# Host port published on the app-VM (192.168.1.25). Traefik routes to
# http://192.168.1.25:${APP_PORT}. 3001 is taken by treningsapp, so default 3002.
APP_PORT=3002

# ── Option B: standalone server with built-in Caddy TLS (compose.prod.yml) ──
# Only needed if you DON'T have an external reverse proxy. Caddy fetches the cert.
# DOMAIN=things.vikane.cloud
# ACME_EMAIL=you@example.com
