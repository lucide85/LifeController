# ─────────────────────────────────────────────────────────────────────────────
# LifeController environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml. Change the password for production!
DATABASE_URL=postgres://lifecontroller:change_me_in_prod@localhost:5432/lifecontroller

# ── Auth.js / NextAuth ────────────────────────────────────────────────────────
# Public URL of the app. For local dev: http://localhost:3000
# For your VPS:  https://your-domain.example
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret:  openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_base64_32

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
#   - OAuth 2.0 Client ID, type "Web application"
#   - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#     (and https://your-domain.example/api/auth/callback/google for prod)
AUTH_GOOGLE_ID=replace_with_google_client_id
AUTH_GOOGLE_SECRET=replace_with_google_client_secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# The email that is ALWAYS treated as the super-admin (auto-approved on first login).
ADMIN_EMAIL=avikane@gmail.com
# Break-glass admin code. Preferred location is settings.json (adminSecureCode),
# but in containerized deploys you can set it here instead. Generate: openssl rand -hex 32
ADMIN_SECURE_CODE=

# ── Anthropic / Claude ──────────────────────────────────────────────────────────
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
# Model used by the search agent (kept current with the latest Claude models).
ANTHROPIC_MODEL=claude-opus-4-8
# Embedding model. Anthropic does not host embeddings, so we use Voyage AI
# (Anthropic's recommended embeddings partner). Get a key at https://www.voyageai.com/
# If left blank, the app falls back to keyword-only search (no semantic recall).
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large

# ── File storage ────────────────────────────────────────────────────────────────
# Local-disk directory where uploaded files/receipts/images are stored.
UPLOAD_DIR=./uploads
# Max upload size in MB.
MAX_UPLOAD_MB=25

# ── Web search fallback ──────────────────────────────────────────────────────────
# The "find docs online" feature uses Claude's built-in web_search tool, which is
# billed through your ANTHROPIC_API_KEY. No extra key required.
ENABLE_WEB_SEARCH=true

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Docker on a VM, compose.prod.yml) — set these for a real deploy.
# ─────────────────────────────────────────────────────────────────────────────
# Your domain (DNS A record must point at the VM's public IP). Caddy gets a free
# Let's Encrypt certificate for it automatically.
DOMAIN=lifecontroller.example.com
# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=you@example.com
# Strong Postgres password used by both the db container and the app's DATABASE_URL
# (compose builds the URL from this). Generate: openssl rand -hex 24
POSTGRES_PASSWORD=replace_with_strong_db_password
#
# In production also set:
#   AUTH_URL=https://${DOMAIN}
#   NEXTAUTH_URL=https://${DOMAIN}
# and the Google OAuth redirect URI to:
#   https://${DOMAIN}/api/auth/callback/google
# (trustHost is already enabled in code so the app works behind the Caddy proxy.)
